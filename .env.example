# Production environment variables for the HP Omen deployment
# Modify these and save as .env in the project root.

# Domain or public IP of your HP Omen (where Cloudflare Tunnel points)
PUBLIC_IP_OR_DOMAIN=tictactoe-api.carelessprojects.xyz

# Nakama port and SSL configuration
NAKAMA_PORT=443
NAKAMA_SSL=true

# Nakama server key (change this for production!)
NAKAMA_SERVER_KEY=defaultkey
